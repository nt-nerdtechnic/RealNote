# Breeze-ASR-25 final correction model (HuggingFace model ID)
BREEZE_ASR_MODEL=MediaTek-Research/Breeze-ASR-25

# Live ASR settings
# LIVE_ASR_BACKEND: mlx (Apple Silicon default) or faster-whisper (CPU fallback)
LIVE_ASR_BACKEND=mlx
# LIVE_ASR_MODEL: tiny / small / medium  (mlx default: medium; CPU recommended: small)
LIVE_ASR_MODEL=medium
LIVE_ASR_DEVICE=cpu
LIVE_ASR_COMPUTE_TYPE=int8
# Language hint for warmup and cold-start (does not force Whisper decode language;
# recording language is controlled by the UI setting)
LIVE_ASR_LANGUAGE=zh
LIVE_ASR_BEAM_SIZE=1
