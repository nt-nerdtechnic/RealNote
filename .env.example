# Breeze-ASR-25 終版校正模型（HuggingFace model ID）
BREEZE_ASR_MODEL=MediaTek-Research/Breeze-ASR-25

# Live ASR 設定
# LIVE_ASR_BACKEND: mlx（Apple Silicon 預設）或 faster-whisper（CPU fallback）
LIVE_ASR_BACKEND=mlx
# LIVE_ASR_MODEL: tiny / small / medium（mlx 預設 medium，CPU 建議 small）
LIVE_ASR_MODEL=medium
LIVE_ASR_DEVICE=cpu
LIVE_ASR_COMPUTE_TYPE=int8
# 暖機與冷啟動語言 hint（不強制 Whisper decode；錄音語言由 UI 設定控制）
LIVE_ASR_LANGUAGE=zh
LIVE_ASR_BEAM_SIZE=1
